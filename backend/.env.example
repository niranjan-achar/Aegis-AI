# FastAPI
AEGIS_APP_NAME=Aegis-AI API
AEGIS_ENV=development
AEGIS_HOST=0.0.0.0
AEGIS_PORT=8000
AEGIS_CORS_ORIGINS=http://localhost:5173

# Redis / Celery
AEGIS_REDIS_URL=redis://localhost:6379/0
AEGIS_CELERY_BROKER_URL=redis://localhost:6379/0
AEGIS_CELERY_RESULT_BACKEND=redis://localhost:6379/1
AEGIS_CACHE_TTL_SECONDS=604800

# Paths
AEGIS_UPLOAD_DIR=tmp/uploads
AEGIS_IMAGE_DIR=tmp/images
AEGIS_XAI_DIR=tmp/xai
AEGIS_MODEL_DIR=models
AEGIS_RULES_DIR=rules
AEGIS_DATA_DIR=data
AEGIS_MLFLOW_TRACKING_URI=file:./mlruns

# Optional cloud/demo settings
AEGIS_R2_ACCOUNT_ID=
AEGIS_R2_ACCESS_KEY_ID=
AEGIS_R2_SECRET_ACCESS_KEY=
AEGIS_R2_BUCKET=
AEGIS_R2_ENDPOINT=
